  textDisplay: {fileID: 0}
  dialogueBox: {fileID: 0}
  typeSpeed: 0.02
  sentances:
  - 'Thank you so much! '
  - 'Now I can shred for the birds once again.  '
  - 'I shall let you continue on your path now. '
  - 'As a thank you, please let me restore your mana for you. '
  - 'Farewell now, and beware The Owl... '
