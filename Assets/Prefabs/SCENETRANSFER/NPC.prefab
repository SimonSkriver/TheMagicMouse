  m_Script: {fileID: 11500000, guid: bd54a8adc49f40b40a59353771983b61, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  textDisplay: {fileID: 0}
  dialogueBox: {fileID: 0}
  typeSpeed: 0.02
  sentances:
  - 'Hey, you there! '
  - 'These corrupted woods seem to have robbed me of my lute... '
  - 'Without it, I can''t calm the bird in the trees. '
  - 'Perhaps, you might be convinced to help me find it? '
  - 'The height of the woods can be troublesome to navigate... '
  - 'Have you considered defying the laws of physics and just jump again midair? '
  - 'Afraid of the heights are you! What are you a man or a mouse? '
  continueButton: {fileID: 0}
  canvas: {fileID: 0}
  hasMet: 0
  actionAsset: {fileID: -944628639613478452, guid: 257aa1856700e784d834192a8bc85c91, type: 3}
  playerRB: {fileID: 0}
  anim: {fileID: 0}
