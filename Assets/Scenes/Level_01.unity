  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  textDisplay: {fileID: 2044549412}
  typeSpeed: 0.02
  sentances:
  - Hey, you there!
  - These corrupted woods have seem to robbed me of my lute...
  - Without it, I can't calm the birds in the trees.
  - Perhaps you might be convinced to help me find it?
  - The height of the woods can be troublesome to navigate...
  - Have you considered trying to defy the laws of physics and just jump again midair?
  - Afraid of heights, are you!? What are you, a man or a mouse?
  continueButton: {fileID: 1722646852}
  lute: {fileID: 1749905109}
  luteScript: {fileID: 1749905113}
